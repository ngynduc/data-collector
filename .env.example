# Telegram API credentials from https://my.telegram.org (API development tools)
# NEVER commit your real .env file.
API_ID=
API_HASH=

# Session name (SQLite session file is stored as <SESSION_NAME>.session)
SESSION_NAME=collector_session

# Optional: path to store the export. Defaults to ./telegram_export
EXPORT_DIR=telegram_export

# Rate limiting / reliability tuning
# Seconds to sleep between dialogs (crawling chats list)
RATE_DIALOG_DELAY=0.5
# Seconds to sleep between message pages
RATE_PAGE_DELAY=1.0
# Seconds to sleep between media downloads
RATE_MEDIA_DELAY=0.5
# Messages per page (Telethon page size)
PAGE_SIZE=100
# Max concurrent media downloads per chat (kept low to avoid FloodWait)
MEDIA_CONCURRENCY=3
# Optional proxy, e.g. socks5://127.0.0.1:1080 or http://host:port
PROXY=
